@inproceedings{bonet-cunhaHybridMarkovChain1996,
  title = {A {{Hybrid Markov Chain Monte Carlo Method}} for {{Generating Permeability Fields Conditioned}} to {{Multiwell Pressure Data}} and {{Prior Information}}},
